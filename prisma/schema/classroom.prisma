model Classroom {
  id              String           @id @default(uuid())

  // Basic Info
  name            String
  institutionName String
  level           InstitutionLevel

  className       String?          
  department      String?          
  groupName       String?          

  description     String?
  joinCode        String           @unique

  // Approval System
  status          ClassroomStatus  @default(PENDING)
  rejectionReason String?

  // Creator
  createdBy       String
  creator         User             @relation("ClassroomCreator", fields: [createdBy], references: [id])

  // Admin resolution
  resolvedBy      String?
  resolver        User?            @relation("ClassroomResolver", fields: [resolvedBy], references: [id])
  resolvedAt      DateTime?

  // Timestamps
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Relations
  memberships     Membership[]
  subjects        Subject[]
  notes           Note[]

  @@index([status])
  @@index([createdBy])
  @@map("classrooms")
}



model Membership {
  id            String          @id @default(uuid())

  userId        String
  classroomId   String

  role          MembershipRole  @default(STUDENT)

  createdAt     DateTime        @default(now())

  // Relations
  user          User            @relation(fields: [userId], references: [id])
  classroom     Classroom       @relation(fields: [classroomId], references: [id])

  @@unique([userId, classroomId])
  @@map("memberships")
}




model Subject {
  id            String      @id @default(uuid())
  name          String

  coverImage    String?

  classroomId   String
  classroom     Classroom   @relation(fields: [classroomId], references: [id])

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  folders       Folder[]     // 🔥 NEW
  notes         Note[]       // optional (notes without folder)

  @@index([classroomId])
  @@map("subjects")
}


model Folder {
  id            String   @id @default(uuid())

  name          String
  coverImage    String?

  subjectId     String
  subject       Subject  @relation(fields: [subjectId], references: [id])

  createdBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  notes         Note[]

  @@index([subjectId])
  @@map("folders")
}


model Note {
  id            String      @id @default(uuid())

  title         String
  description   String?

  status        NoteStatus  @default(PENDING)

  classroomId   String
  subjectId     String
  folderId      String?     // 🔥 OPTIONAL

  uploadedBy    String
  approvedBy    String?

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  classroom     Classroom   @relation(fields: [classroomId], references: [id])
  subject       Subject     @relation(fields: [subjectId], references: [id])
  folder        Folder?     @relation(fields: [folderId], references: [id])

  uploader      User        @relation("UserNotes", fields: [uploadedBy], references: [id])
  approver      User?       @relation("ApprovedBy", fields: [approvedBy], references: [id])

  files         NoteFile[]
  favorites     Favorite[]
  comments      Comment[]

  @@index([classroomId])
  @@index([subjectId])
  @@index([folderId])
  @@map("notes")
}

model NoteFile {
  id        String   @id @default(uuid())

  url       String   // Cloudinary URL
  type      String   // pdf | image
  fileName  String?  // 🔥 optional (nice UX)
  fileSize  Int?     // 🔥 optional

  noteId    String
  note      Note     @relation(fields: [noteId], references: [id])

  createdAt DateTime @default(now())

  @@index([noteId])
  @@map("note_files")
}


model Favorite {
  id        String   @id @default(uuid())
  userId    String
  noteId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@unique([userId, noteId])
}




model Comment {
  id        String   @id @default(uuid())

  content   String

  // Which note this comment belongs to
  noteId    String
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)

  // Author
  userId    String
  user      User     @relation("UserComments", fields: [userId], references: [id], onDelete: Cascade)

  // ── Reply system ────────────────────────────────────────────────────────
  // Self-relation: top-level comments have parentId = null
  // Replies point to a top-level comment — only ONE level deep (Facebook style)
  // A reply cannot itself be replied to (enforced in service layer)
  parentId  String?
  parent    Comment?   @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[]  @relation("CommentReplies")

  // ── Like system ─────────────────────────────────────────────────────────
  likes     CommentLike[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([noteId])
  @@index([userId])
  @@index([parentId])
  @@map("comments")
}





model CommentLike {
  id        String   @id @default(uuid())

  userId    String
  commentId String

  user      User     @relation("UserCommentLikes", fields: [userId], references: [id], onDelete: Cascade)
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  // One like per user per comment
  @@unique([userId, commentId])
  @@index([commentId])
  @@map("comment_likes")
}

